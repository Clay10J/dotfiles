#!/usr/bin/env bash
set -euo pipefail

echo "🔑 Setting up 1Password sign-in..."

# Only run once, after the CLI has been installed
if ! command -v op >/dev/null 2>&1; then
  echo "❌ 1Password CLI not found; sign-in failed"
  echo "   This may indicate that 1Password CLI installation failed"
  exit 1
fi

echo "🔐 Starting 1Password sign-in process..."
if eval "$(op signin)"; then
  echo "✅ 1Password sign-in completed successfully"
else
  echo "❌ 1Password sign-in failed"
  echo "   Please check your credentials and try again"
  exit 1
fi
