#!/usr/bin/env bash
set -e

echo "🔤 Installing custom fonts..."

# Only run on Linux hosts
if [ "$(uname -s)" != "Linux" ]; then
  exit 0
fi

FONT_DIR="$HOME/.local/share/fonts"
mkdir -p "$FONT_DIR"

# 1) Install CaskaydiaCove Nerd Font (formerly CascadiaCode)
echo "🔽 Installing CaskaydiaCove Nerd Font"
NERD_BASE_URL="https://github.com/ryanoasis/nerd-fonts/releases/latest/download"
curl -fsSL "$NERD_BASE_URL/CaskaydiaCove.zip" -o "$FONT_DIR/CaskaydiaCove.zip"
unzip -o "$FONT_DIR/CaskaydiaCove.zip" -d "$FONT_DIR"

# 2) Install Iosevka Nerd Font
echo "🔽 Installing Iosevka Nerd Font"
curl -fsSL "$NERD_BASE_URL/Iosevka.zip" -o "$FONT_DIR/Iosevka.zip"
unzip -o "$FONT_DIR/Iosevka.zip" -d "$FONT_DIR"

# 3) Install Maple Mono NF from its own repo
echo "🔽 Installing Maple Mono NF"
MAPLE_URL="https://github.com/subframe7536/maple-font/releases/latest/download/MapleMono-NF-unhinted.zip"
curl -fsSL "$MAPLE_URL" -o "$FONT_DIR/MapleMono.zip"
unzip -o "$FONT_DIR/MapleMono.zip" -d "$FONT_DIR"

# 4) Clean up zip files
rm -f "$FONT_DIR"/*.zip

# 5) Refresh the font cache
echo "🔄 Refreshing font cache..."
fc-cache -f "$FONT_DIR"

echo "✅ Custom fonts installed successfully"
