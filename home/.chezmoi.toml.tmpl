passwordManager = "1password"
dataDir = ".chezmoidata"
scriptsDir = ".chezmoiscripts"

# —————— per-host overrides ——————

[host."commander"]
sshAgent = true
headless = false

# —————— hooks ——————

[hooks.init.after]
commands = [
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_install_password_manager.sh",
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_signin_1password.sh",
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_generate_ssh_key.sh",
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_install_packages.sh",
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_install_tools.sh",
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_set_default_shell.sh",
]
