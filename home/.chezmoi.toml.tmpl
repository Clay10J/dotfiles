passwordManager = "1password"
dataDir = ".chezmoidata"
scriptsDir = ".chezmoiscripts"

# —————— hooks ——————

[hooks.init.after]
commands = [
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_set_git_remote.sh",
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_setup_repositories.sh",
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_install_packages.sh",
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_signin_1password.sh",
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_generate_ssh_key.sh",
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_install_fonts.sh",
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_install_kitty.sh",
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_install_starship.sh",
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_install_uv.sh"
]

[hooks.apply.after]
commands = [
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_fix_ssh_permissions.sh",
  "{{ .chezmoi.sourceDir }}/.chezmoiscripts/run_once_set_default_shell.sh"
]
