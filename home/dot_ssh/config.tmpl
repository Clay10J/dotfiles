# ~/.ssh/config.tmpl

{{- $host := index .data .chezmoi.hostname -}}
{{- $sshUser := .chezmoi.user -}}
{{- $sshAgent := true -}}

{{- if $host -}}
  {{- $sshUser = $host.sshUser -}}
  {{- $sshAgent = $host.sshAgent -}}
{{- end -}}

Host *
  User {{ $sshUser }}
  HostKeyAlgorithms +ssh-ed25519

{{- if $sshAgent -}}
# — 1Password SSH agent on "{{ .chezmoi.hostname }}" —
  IdentityAgent {{ print .chezmoi.homeDir }}/.1password/agent.sock
  AddKeysToAgent yes
  ForwardAgent yes
{{- else -}}
# — Fallback to on-disk key for headless or non-agent hosts —
  IdentityFile {{ print .chezmoi.homeDir }}/.ssh/id_ed25519
  IdentitiesOnly yes
{{- end -}}
